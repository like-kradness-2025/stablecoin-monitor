# v3.00 uses CCXT public OHLCV. No exchange API key is required for the default setup.
DISCORD_WEBHOOK_URL=
DB_PATH=data/stablecoin_monitor.db
OUTPUT_DIR=output

# Legacy fallback only. Prefer FETCH_INTERVAL_SECONDS / RENDER_INTERVAL_SECONDS.
POLL_INTERVAL_SECONDS=300
FETCH_INTERVAL_SECONDS=60
RENDER_INTERVAL_SECONDS=300

# CCXT OHLCV settings
MARKETS_CONFIG_PATH=config/markets.yaml
OHLCV_TIMEFRAME=1m
OHLCV_LIMIT=120
HISTORY_DAYS=1
RETENTION_DAYS=30
REQUEST_TIMEOUT_SECONDS=20
FLOW_DELTA_THRESHOLD_QUOTE=1000000
